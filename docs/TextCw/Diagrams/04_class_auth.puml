@startuml
skinparam backgroundColor white
skinparam classBorderColor black
skinparam classBackgroundColor white
skinparam classHeaderBackgroundColor #CCCCCC
skinparam classHeaderFontColor black
skinparam classFontColor black
skinparam arrowColor black
skinparam linetype ortho

title Диаграмма классов: auth-service

class AuthHandler {
    - auth : IAuthService
    - logger : *slog.Logger
    + register(w, r)
    + login(w, r)
    + live(w, r)
    + ready(w, r)
    + metrics(w, r)
}

class RegisterRequest {
    + Email : string
    + Password : string
    + FullName : string
    + Role : string
}

class LoginRequest {
    + Email : string
    + Password : string
}

class LoginResponse {
    + AccessToken : string
    + User : UserDTO
}

class UserDTO {
    + ID : string
    + Email : string
    + FullName : string
    + Role : string
}

class User {
    + ID : string
    + Email : string
    + FullName : string
    + Role : string
    + PasswordHash : string
    + IsActive : bool
    + CreatedAt : time.Time
    + UpdatedAt : time.Time
}

class AuthService {
    - repo : IUserRepository
    - jwtSecret : string
    - tokenTTL : time.Duration
    + Register(ctx, req) : User, error
    + Login(ctx, req) : string, User, error
    + Ping(ctx) : error
}

interface IAuthService {
    + Register(ctx, req) : User, error
    + Login(ctx, req) : string, User, error
    + Ping(ctx) : error
}

interface IUserRepository {
    + CreateUser(ctx, user) : User, error
    + GetByEmail(ctx, email) : User, error
    + Ping(ctx) : error
}

class UserRepository {
    - db : *pgxpool.Pool
    + CreateUser(ctx, user) : User, error
    + GetByEmail(ctx, email) : User, error
    + Ping(ctx) : error
}

class Config {
    + DBURL : string
    + JWTSecret : string
    + TokenTTLMinutes : int
    + HTTPPort : string
    + ServiceName : string
}

AuthHandler --> IAuthService
AuthHandler ..> RegisterRequest
AuthHandler ..> LoginRequest
AuthHandler ..> LoginResponse
LoginResponse --> UserDTO
AuthService ..|> IAuthService
AuthService --> IUserRepository
UserRepository ..|> IUserRepository
AuthService --> "0..*" User : manages
UserRepository --> "0..*" User : persists
AuthHandler --> Config

@enduml
